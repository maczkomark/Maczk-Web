NEXT_PUBLIC_SITE_URL=https://maczkoweb.hu

# Külső form-handler (VPS: api.maczkoweb.hu).
# Ha mindkettő ki van töltve, az űrlap a VPS-szerverre POST-ol,
# egyébként a lokális /api/quote route-ra fallback-el (dev).
#
# Token generálása a VPS-en:
#   cd /opt/multipro-form
#   npm run token -- \
#     --name "Maczkó Web" \
#     --to "maczkomark08@gmail.com" \
#     --origin "https://maczkoweb.hu" \
#     --origin "https://www.maczkoweb.hu" \
#     --fromName "Maczkó Web — Árajánlatkérés" \
#     --subject "Új árajánlatkérés a maczkoweb.hu-ról"
#
# A kimenetből másold ki a teljes tokent ide:
NEXT_PUBLIC_FORM_ENDPOINT=https://api.maczkoweb.hu/api/contact
NEXT_PUBLIC_FORM_TOKEN=

# Lokális /api/quote fallback-hez (csak ha NEM a VPS-t használod):
RESEND_API_KEY=
QUOTE_TO_EMAIL=hello@maczkoweb.hu
